{
  "name": "seestar-imaging-logger",
  "version": "1.0.0",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "seestar-log": "dist/index.js"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "seestar",
    "s30-pro",
    "astrophotography",
    "fits",
    "imaging-log",
    "google-sheets",
    "astronomy",
    "windows"
  ],
  "author": "Chris Gardner",
  "license": "MIT",
  "description": "CLI tool to process Seestar S30 Pro FITS files into grouped imaging sessions with CSV and Google Sheets export",
  "dependencies": {
    "@types/node": "^25.5.0",
    "commander": "^14.0.3",
    "csv-stringify": "^6.7.0",
    "fast-glob": "^3.3.3",
    "fitsjs-ng": "^1.0.2",
    "fs-extra": "^11.3.4",
    "googleapis": "^171.4.0",
    "jsfitsio": "^1.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "@observerly/fits": {
      "os": [
        "darwin",
        "linux",
        "win32"
      ]
    }
  }
}
